{
  "name": "data-architecture-blueprint-slides",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "slidev slides.md --open",
    "build": "slidev build slides.md --out dist",
    "export": "slidev export slides.md --output dist/data_architecture_blueprint.pdf --timeout 120000",
    "postinstall": "test -L pages/diagrams || ln -sf ../../docs/assets/diagrams pages/diagrams"
  },
  "devDependencies": {
    "@slidev/cli": "^52.0.0",
    "playwright-chromium": "^1.60.0"
  },
  "dependencies": {
    "@slidev/theme-seriph": "^0.25.0"
  }
}
